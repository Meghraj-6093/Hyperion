# Hyperion Environment Variables
# ===============================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any .env file with real secrets to git.
#
# Required for Next.js builds:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Required for authentication (keep secret — NEVER commit):
# CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Required for database (Supabase):
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
